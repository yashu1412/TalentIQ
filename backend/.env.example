# ─────────────────────────────────────────────────────────────────────────────
# TalentIQ Backend — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production                  # "development" or "production"
PORT=8000

# ── Database (Supabase / Neon / any Postgres) ─────────────────────────────────
# Must use the async driver scheme: postgresql+psycopg_async://
DATABASE_URL=postgresql+psycopg_async://USER:PASSWORD@HOST:5432/DATABASE

# ── Redis (Upstash / Railway Redis / self-hosted) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk JWT Public Key — get from Clerk Dashboard → API Keys → PEM Public Key
# Required for production JWT verification. Must start with "-----BEGIN PUBLIC KEY-----"
CLERK_JWT_PUBLIC_KEY=

# Optional: your Clerk issuer URL (https://<your-clerk-instance>.clerk.accounts.dev)
CLERK_JWT_ISSUER=

# Set to "true" ONLY for local development (skips JWT signature check)
ALLOW_INSECURE_JWT_DECODE=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://talentiq.vercel.app,https://www.talentiq.app
ALLOWED_ORIGINS=http://localhost:3000

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-4-31b-it:free

# Fallback OpenAI key (optional)
OPENAI_API_KEY=sk-...

# ── Stream.io (Live rooms / Chat) ────────────────────────────────────────────
STREAM_API_KEY=...
STREAM_API_SECRET=...

# ── Piston (Code Execution) ───────────────────────────────────────────────────
# Self-host piston or leave blank to disable the code execution feature
PISTON_URL=http://localhost:2000

# ── Optional: skip DB bootstrap on cold start ────────────────────────────────
# SKIP_DB_BOOTSTRAP=false

# ── Autobot — Job Application Bot ────────────────────────────────────────────
# Credentials for automated job applications (server-side only, never exposed to frontend)

# LinkedIn
AUTOBOT_LINKEDIN_EMAIL=your.email@example.com
AUTOBOT_LINKEDIN_PASSWORD=your_linkedin_password

# Naukri (leave blank if not using, bot will use SSO/manual login)
AUTOBOT_NAUKRI_EMAIL=
AUTOBOT_NAUKRI_PASSWORD=

# Y Combinator / Work at a Startup
AUTOBOT_YC_EMAIL=
AUTOBOT_YC_PASSWORD=

# Personal info (used to fill application forms)
AUTOBOT_FULL_NAME=Your Full Name
AUTOBOT_PHONE=+91-9999999999
AUTOBOT_CITY=Mumbai
AUTOBOT_COUNTRY=India
AUTOBOT_LINKEDIN_URL=https://linkedin.com/in/your-username
AUTOBOT_PORTFOLIO_URL=
AUTOBOT_GITHUB_URL=

# Experience profile
AUTOBOT_YEARS_EXP=1
AUTOBOT_CURRENT_TITLE=Software Engineer
AUTOBOT_EDUCATION=Bachelor's Degree
AUTOBOT_NOTICE_PERIOD=0
AUTOBOT_SALARY=negotiable
AUTOBOT_SKILLS=Python,JavaScript,React,Next.js,Node.js,TypeScript

# Resume file path (relative to backend/ dir, or absolute)
AUTOBOT_CV_PATH=uploads/resume.pdf
AUTOBOT_RESUME_SUMMARY=Full Stack Developer with experience in React, Next.js, and FastAPI.

# AI key for autobot form-filling (reuses main OPENROUTER_API_KEY if not set)
# AUTOBOT_OPENROUTER_API_KEY=sk-or-v1-...
