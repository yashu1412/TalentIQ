# ─────────────────────────────────────────────────────────────────────────────
# TalentIQ Backend — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production                  # "development" or "production"
PORT=8000

# ── Database (Supabase / Neon / any Postgres) ─────────────────────────────────
# Must use the async driver scheme: postgresql+psycopg_async://
DATABASE_URL=postgresql+psycopg_async://USER:PASSWORD@HOST:5432/DATABASE

# ── Redis (Upstash / Railway Redis / self-hosted) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk JWT Public Key — get from Clerk Dashboard → API Keys → PEM Public Key
# Required for production JWT verification. Must start with "-----BEGIN PUBLIC KEY-----"
CLERK_JWT_PUBLIC_KEY=

# Optional: your Clerk issuer URL (https://<your-clerk-instance>.clerk.accounts.dev)
CLERK_JWT_ISSUER=

# Set to "true" ONLY for local development (skips JWT signature check)
ALLOW_INSECURE_JWT_DECODE=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://talentiq.vercel.app,https://www.talentiq.app
ALLOWED_ORIGINS=http://localhost:3000

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-4-31b-it:free

# Fallback OpenAI key (optional)
OPENAI_API_KEY=sk-...

# ── Stream.io (Live rooms / Chat) ────────────────────────────────────────────
STREAM_API_KEY=...
STREAM_API_SECRET=...

# ── Piston (Code Execution) ───────────────────────────────────────────────────
# Self-host piston or leave blank to disable the code execution feature
PISTON_URL=http://localhost:2000

# ── Optional: skip DB bootstrap on cold start ────────────────────────────────
# SKIP_DB_BOOTSTRAP=false
